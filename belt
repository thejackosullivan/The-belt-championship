    /* CHAMPION ROLL */
    .champion-roll { border: 1px solid var(--parchment-dark); border-radius: 4px; overflow: hidden; }

    .champion-row {
      display: flex;
      align-items: center;
      padding: 14px 18px;
      border-bottom: 1px solid var(--parchment-dark);
      gap: 16px;
      background: var(--parchment);
      transition: background 0.15s;
    }

    .champion-row:last-child { border-bottom: none; }
    .champion-row:hover { background: var(--cream); }

    .champion-row.goat-row { background: linear-gradient(90deg, rgba(184,150,62,0.12), var(--parchment)); }
    .champion-row.void-row { background: linear-gradient(90deg, rgba(139,58,42,0.08), var(--parchment)); }

    .champ-year {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--muted);
      width: 44px;
      flex-shrink: 0;
    }

    .void-year { color: var(--rust); }

    .champ-body { flex: 1; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

    .champ-name { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--olive); }
    .champ-name.muted { color: var(--muted); font-style: italic; font-weight: 400; }

    .badge {
      font-size: 8px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 2px;
      font-family: 'Libre Baskerville', serif;
      font-weight: 700;
      white-space: nowrap;
    }

    .badge-gold { background: var(--gold); color: var(--olive); }
    .badge-void { background: var(--rust); color: white; }
    .badge-goat { background: var(--gold); color: var(--olive); }
    .badge-not-played { background: var(--parchment-dark); color: var(--muted); }

    /* STAT BOXES */
    .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }

    .stat-box {
      background: var(--parchment);
      border: 1px solid var(--parchment-dark);
      border-top: 3px solid var(--olive);
      border-radius: 4px;
      padding: 16px;
      text-align: center;
    }

    .stat-number { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 900; color: var(--olive); line-height: 1; }
    .stat-label { font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-top: 4px; display: block; }
    .stat-note { font-family: 'IM Fell English', serif; font-style: italic; font-size: 0.78rem; color: var(--muted); margin-top: 3px; }

