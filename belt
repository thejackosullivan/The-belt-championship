  <style>
    :root {
      --cream: #f5f0e8;
      --parchment: #ede5d0;
      --parchment-dark: #d9cdb4;
      --olive: #2c3a1e;
      --olive-mid: #3d5229;
      --olive-light: #5a7a3a;
      --gold: #b8963e;
      --gold-light: #d4aa55;
      --gold-pale: #f0e0a0;
      --rust: #8b3a2a;
      --rust-light: #c0523a;
      --ink: #1a1a14;
      --muted: #7a7060;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
