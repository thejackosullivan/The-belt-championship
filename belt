      padding: 28px 24px 22px;
      text-align: center;
    }

    .logo-wrap { display: flex; align-items: center; justify-content: center; gap: 18px; flex-wrap: wrap; }
    .logo-img { height: 80px; width: auto; filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5)); }
    .site-title-block { text-align: left; }
    .site-eyebrow { font-family: 'Libre Baskerville', serif; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold-light); display: block; margin-bottom: 4px; }
    .site-title { font-family: 'Playfair Display', Georgia, serif; font-size: 2.6rem; font-weight: 900; color: var(--cream); line-height: 1; }
    .site-subtitle { font-family: 'IM Fell English', Georgia, serif; font-style: italic; color: var(--gold-light); font-size: 0.95rem; margin-top: 5px; }

    .site-nav {
      background-color: var(--olive-mid);
      border-bottom: 2px solid var(--gold);
      padding: 0 16px;
      display: flex;
      justify-content: center;
      gap: 0;
      flex-wrap: wrap;
    }

    .site-nav a { font-family: 'Libre Baskerville', serif; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--parchment); text-decoration: none; padding: 12px 14px; border-right: 1px solid rgba(255,255,255,0.08); transition: color 0.2s, background 0.2s; }
    .site-nav a:first-child { border-left: 1px solid rgba(255,255,255,0.08); }
    .site-nav a:hover { color: var(--gold-light); background: rgba(255,255,255,0.05); }
    .site-nav a.active { color: var(--gold-light); }

    .page-wrap { max-width: 760px; margin: 0 auto; padding: 0 20px 60px; }

    .page-hero {
      background: var(--olive);
      border: 2px solid var(--gold);
      border-top: none;
